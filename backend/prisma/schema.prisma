generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  REP
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(REP)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customers     Customer[]      @relation("CustomerOwner")
  meetingNotes  MeetingSummary[]
  followUps     FollowUpEmail[]
  chatMessages  ChatMessage[]
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  company     String?
  email       String?
  phone       String?
  status      String   @default("lead") // lead, active, churned, etc.
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?
  owner       User?    @relation("CustomerOwner", fields: [ownerId], references: [id])

  files          FileAttachment[]
  meetingNotes   MeetingSummary[]
  followUps      FollowUpEmail[]
  chatMessages   ChatMessage[]
}

model FileAttachment {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  createdAt   DateTime @default(now())
}

model MeetingSummary {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  rawNotes    String
  summary     String
  actionItems String?
  createdAt   DateTime @default(now())
}

model FollowUpEmail {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  subject     String
  body        String
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id          String   @id @default(uuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  role        String   // "user" | "assistant"
  content     String
  createdAt   DateTime @default(now())
}
