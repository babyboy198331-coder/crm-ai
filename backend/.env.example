DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_ai?schema=public"
JWT_SECRET="change-this-to-a-long-random-string"

# --- AI provider ---
# Uses any OpenAI-compatible API. Defaults to OpenAI; to use Groq instead,
# set OPENAI_BASE_URL and OPENAI_MODEL as shown below (commented out).
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"

# --- Groq example (uncomment to use Groq instead of OpenAI) ---
# OPENAI_API_KEY="gsk_..."
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="openai/gpt-oss-120b"

PORT=4000
CORS_ORIGIN="http://localhost:3000"
